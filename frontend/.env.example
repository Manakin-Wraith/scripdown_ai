# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Backend API URL
VITE_API_URL=http://localhost:5000

FLASK_APP=app.py
FLASK_ENV=development

# Supabase Configuration (Backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
# Add service role key from Supabase dashboard for server-side operations
SUPABASE_SERVICE_KEY=your_service_role_key_here
# JWT Secret for token verification (from Supabase Dashboard → Project Settings → API → JWT Settings)
SUPABASE_JWT_SECRET=your_jwt_secret_here

# AI Keys
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: for AI scene detection
OPENAI_API_KEY=your_openai_api_key_here

# Email Service (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
# From email address (must be verified in Resend or use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=hello@slateone.studio

# Frontend URL (for invite links and email redirects)
FRONTEND_URL=https://app.slateone.studio

# Notel Supabase (for waitlist access)
NOTEL_SUPABASE_URL=https://your-notel-project.supabase.co
NOTEL_SUPABASE_SERVICE_KEY=your_notel_service_key_here
