{
    "HOD_schemas": {
      "Director": {
        "tables": [
          {
            "name": "director_notes",
            "columns": [
              {"name": "scene_number", "type": "INTEGER", "constraints": ["FOREIGN KEY REFERENCES scenes(scene_number)"]},
              {"name": "scene_summary", "type": "TEXT"},
              {"name": "emotional_beats", "type": "TEXT"},
              {"name": "shot_suggestions", "type": "TEXT"}
            ]
          }
        ]
      },
      "Producer": {
        "tables": [
          {
            "name": "producer_notes",
            "columns": [
              {"name": "scene_number", "type": "INTEGER", "constraints": ["FOREIGN KEY REFERENCES scenes(scene_number)"]},
              {
                "name": "budget_estimation",
                "type": "JSON",
                "columns":[
                    {"name":"location", "type":"TEXT"},
                    {"name":"props", "type":"TEXT"},
                    {"name":"wardrobe", "type":"TEXT"}
                ]
              },
              {
                "name": "scheduling_assistance",
                "type": "JSON",
                "columns":[
                  {"name":"location_type", "type":"TEXT"},
                  {"name":"actor_availability", "type":"TEXT"},
                  {"name":"estimated_time", "type":"TEXT"}
                ]
              },
              {
                "name": "progress_tracking",
                "type": "JSON",
                "columns":[
                  {"name":"breakdown_status", "type":"TEXT"},
                  {"name":"team_contributions", "type":"JSON"}
                ]
              }
            ]
          }
        ]
      },
      "DoP": {
        "tables": [
          {
            "name": "dop_notes",
            "columns": [
              {"name": "scene_number", "type": "INTEGER", "constraints": ["FOREIGN KEY REFERENCES scenes(scene_number)"]},
              {"name": "lighting_visual_cues", "type": "TEXT"},
              {"name": "scene_analytics", "type": "TEXT"},
              {"name": "equipment_needs", "type": "TEXT"}
            ]
          }
        ]
      },
      "Production_Designer": {
        "tables": [
          {
            "name": "production_designer_notes",
            "columns": [
              {"name": "scene_number", "type": "INTEGER", "constraints": ["FOREIGN KEY REFERENCES scenes(scene_number)"]},
              {"name": "set_dressing_requirements", "type": "TEXT"},
              {"name": "props_and_wardrobe", "type": "TEXT"},
               {"name":"collaboration", "type":"TEXT"}
            ]
          }
        ]
      },
      "Costume_Designer": {
        "tables": [
          {
            "name": "costume_designer_notes",
            "columns": [
              {"name": "scene_number", "type": "INTEGER", "constraints": ["FOREIGN KEY REFERENCES scenes(scene_number)"]},
              {"name": "wardrobe_breakdown", "type": "TEXT"},
              {"name": "continuity_management", "type": "TEXT"}
            ]
          }
        ]
      },
      "Casting_Director": {
        "tables": [
          {
            "name": "casting_director_notes",
            "columns": [
              {"name": "scene_number", "type": "INTEGER", "constraints": ["FOREIGN KEY REFERENCES scenes(scene_number)"]},
              {
                "name": "character_breakdown",
                "type": "JSON",
                 "columns":[
                    {"name":"character_name", "type":"TEXT"},
                    {"name":"role_type", "type":"TEXT"},
                    {"name":"importance", "type":"TEXT"}
                  ]
              },
              {
                "name": "dialogue_analytics",
                "type": "JSON"
              }
            ]
          }
        ]
      },
      "Location_Manager": {
        "tables": [
          {
            "name": "location_manager_notes",
            "columns": [
              {"name": "scene_number", "type": "INTEGER", "constraints": ["FOREIGN KEY REFERENCES scenes(scene_number)"]},
              {"name": "location_breakdown", "type": "TEXT"},
                {"name": "logistics_planning", "type": "TEXT"}
            ]
          }
        ]
      },
      "VFX_Supervisor": {
        "tables": [
          {
            "name": "vfx_supervisor_notes",
            "columns": [
              {"name": "scene_number", "type": "INTEGER", "constraints": ["FOREIGN KEY REFERENCES scenes(scene_number)"]},
              {"name": "vfx_requirements", "type": "TEXT"},
              {"name": "budget_inputs", "type": "TEXT"}
            ]
          }
        ]
      },
        "Sound_Department": {
        "tables": [
          {
            "name": "sound_department_notes",
            "columns": [
               {"name": "scene_number", "type": "INTEGER", "constraints": ["FOREIGN KEY REFERENCES scenes(scene_number)"]},
              {"name": "sound_breakdown", "type": "TEXT"},
               {"name": "music_cues", "type": "TEXT"}
            ]
          }
        ]
      },
      "Makeup_and_Hair": {
        "tables": [
          {
            "name": "makeup_and_hair_notes",
            "columns": [
                {"name": "scene_number", "type": "INTEGER", "constraints": ["FOREIGN KEY REFERENCES scenes(scene_number)"]},
              {"name": "character_profiles", "type": "TEXT"},
               {"name": "scene_consistency", "type": "TEXT"}
            ]
          }
        ]
      },
      "Script_Writer": {
          "tables": [
              {
                  "name": "script_writer_notes",
                   "columns": [
                      {"name": "scene_number", "type": "INTEGER", "constraints": ["FOREIGN KEY REFERENCES scenes(scene_number)"]},
                       {"name": "writer_notes", "type": "TEXT"},
                       {"name": "version_history", "type": "JSON"}
                   ]
              }
          ]
      },
        "Actor": {
          "tables": [
              {
                  "name": "actor_notes",
                   "columns": [
                      {"name": "scene_number", "type": "INTEGER", "constraints": ["FOREIGN KEY REFERENCES scenes(scene_number)"]},
                      {"name": "character_name", "type": "TEXT"},
                       {"name": "actor_notes", "type": "TEXT"},
                        {"name": "performance_notes", "type": "TEXT"}
                   ]
              }
          ]
      }
    }
  }
  